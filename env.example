# ── Copy this to .env and fill in the values ──────────────────────────────

# Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Supabase (supabase.com → your project → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyYOUR_SERVICE_ROLE_KEY

# JWT secret — type any long random string, e.g. "myapp_super_secret_2024_xyz"
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Gmail App Password (myaccount.google.com → Security → App passwords)
EMAIL_USER=yourname@gmail.com
EMAIL_APP_PASS=xxxx-xxxx-xxxx-xxxx

# Your deployed server URL (fill after deploying to Railway)
SERVER_URL=https://YOUR_APP.railway.app

# Your frontend URL (fill after deploying to Netlify)
CLIENT_URL=https://YOUR_APP.netlify.app

PORT=3000
